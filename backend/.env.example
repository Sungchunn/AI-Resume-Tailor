# Backend Application Configuration
# Copy this file to .env and fill in real values
#
# This is the SINGLE SOURCE OF TRUTH for:
# - AI provider keys (OpenAI, Gemini)
# - Database connection strings
# - All backend application settings
#
# Used by: Digital Ocean deployment, local non-Docker dev, Docker (via env_file)

# Database (PostgreSQL)
# For local Docker:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/resume_tailor

# For Supabase (recommended - use Transaction Pooler for free tier):
# 1. Go to Supabase Dashboard > Project Settings > Database > Connection Pooling
# 2. Copy the "Transaction" mode connection string
# 3. IMPORTANT: Add ?prepared_statement_cache_size=0 for asyncpg compatibility
DATABASE_URL=postgresql+asyncpg://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?prepared_statement_cache_size=0

# Sync URL for Alembic migrations (use direct connection for DDL operations):
DATABASE_URL_SYNC=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# MongoDB
# For local Docker:
# MONGODB_URI=mongodb://mongouser:mongopass@localhost:27017/resume_tailor?authSource=admin
# For MongoDB Atlas (replace placeholders):
MONGODB_URI=mongodb+srv://[USERNAME]:[PASSWORD]@[CLUSTER].mongodb.net/resume_tailor?retryWrites=true&w=majority
MONGODB_DATABASE=resume_tailor

# Redis
# For local Docker:
# REDIS_URL=redis://localhost:6379
# For Upstash (replace placeholders):
REDIS_URL=rediss://default:[PASSWORD]@[ENDPOINT].upstash.io:6379
UPSTASH_REDIS_REST_URL=https://[ENDPOINT].upstash.io
UPSTASH_REDIS_REST_TOKEN=[TOKEN]

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Provider Selection (options: "openai" or "gemini")
AI_PROVIDER=openai

# AI Provider (OpenAI) - Default
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# AI Provider (Gemini) - Alternative to OpenAI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Environment
ENVIRONMENT=development

# CORS Configuration (comma-separated list of origins)
CORS_ORIGINS=http://localhost:3000

# File Storage (MinIO/S3)
# Set STORAGE_ENABLED=true to store original uploaded files
# Requires MinIO running locally or S3 credentials configured
STORAGE_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=resumes
MINIO_SECURE=false

# Proxy Configuration
TRUST_PROXY=false

# Admin Authentication (comma-separated email addresses)
ADMIN_EMAILS=admin@example.com

# APIFY Integration (Direct LinkedIn Scraping)
# Get your token from: https://console.apify.com/account/integrations
APIFY_API_TOKEN=PASTE_YOUR_APIFY_TOKEN_HERE
APIFY_ACTOR_ID=hKByXkMQaC5Qt9UMN
APIFY_TIMEOUT_SECONDS=300
APIFY_MAX_RETRIES=3
APIFY_MEMORY_MBYTES=1024  # Memory for actor (256, 512, 1024, 2048, 4096) - higher = fewer OOM errors

# Scraper Schedule (UTC)
SCRAPER_SCHEDULE_HOUR=6
SCRAPER_SCHEDULE_MINUTE=0
SCRAPER_ENABLED=true

# Job Retention (automatic cleanup)
JOB_RETENTION_DAYS=21
JOB_CLEANUP_ENABLED=true

# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_ENABLED=false
